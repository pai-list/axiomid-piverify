{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "axiomid-piverify",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": ["nodejs_compat"],
  "ai": { "binding": "AI" },
  "kv_namespaces": [
    { "binding": "PASSPORTS" }
  ],
  "vars": {
    "FRAMEWORK_VERSION": "1.0.0",
    "DEFAULT_MODEL": "@cf/meta/llama-3.1-8b-instruct"
  }
}